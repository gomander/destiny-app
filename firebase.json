{
  "hosting": {
    "site": "darci-gg",
    "public": "dist/spa",
    "rewrites": [
      {
        "source": "**",
        "destination": "/index.html"
      }
    ],
    "headers": [
      {
        "source": "*.html",
        "headers": [ {
          "key": "Cache-Control",
          "value": "no-cache"
        } ]
      },
      {
        "source": "**/*.@(js|css|ico)",
        "headers": [ {
          "key": "Cache-Control",
          "value": "max-age=5184000"
        } ]
      },
      {
        "source": "**/*.@(jpg|jpeg|gif|png|svg)",
        "headers": [ {
          "key": "Cache-Control",
          "value": "max-age=7776000"
        } ]
      },
      {
        "source": "**/*.@(ttf|woff|woff2|mp3)",
        "headers": [ {
          "key": "Cache-Control",
          "value": "max-age=15552000"
        } ]
      }
    ]
  }
}
